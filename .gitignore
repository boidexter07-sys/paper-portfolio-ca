# Dependencies
node_modules/
.pnp/
.pnp.js

# Next.js build output
.next/
.next.corrupt/
.next.stale_novendor/
out/
.swc/

# Build info
tsconfig.tsbuildinfo
*.tsbuildinfo

# Local SQLite databases (paper portfolio uses SQLite)
# T46: the shipped demo DB at data/paperportfolio.db is intentionally
# committed to the repo (negated below) so friends can log in to the
# Vercel-deployable demo. All other DB files stay local.
*.db
*.db-wal
*.db-shm
dev.db
dev.db-journal
data/*.db
data/*.db-wal
data/*.db-shm
# DO NOT commit any other DB files in data/ (e.g. *.db.test.*, *.db.bak.*, *.db.broken)
!data/paperportfolio.db
!data/paperportfolio.db-wal
!data/paperportfolio.db-shm

# Environment files (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Coverage / CI artifacts
coverage/
.nyc_output/

# Internal scratch files — NOT for public sharing
# (Kanban QA artifacts, Lighthouse JSON, motion demo binaries, build reports,
# spec docs, atlas scripts, internal numbered scripts)
/v6-build-report.md
/v6-motion-demo.mp4
/v6-motion-demo.webm
/l3-news-spec.md
/SETUP.md
qa/
screenshots/
# But Next.js serves /public directly, so asset screenshots under
# public/screenshots/ must be tracked (they're the source of truth
# for the v8 landing page surface tiles).
!public/screenshots/
_atlas_*.js
_t*_*.js
_t*.js
_t*.ts
_shot_*.js
_lighthouse_*.js
_motion_demo.js
_reduced_motion_test.js
_l3_*.ts
_smoke_*.ts
_yfinance_pull.py
# T46 seed/test scratch files (created during build, never shipped)
_seed_preflight.js
_seed_verify.js
_dedupe_events.js
_inspect_events.js
_inspect_users.js
_tsx_check.js
inspect_db.js
inspect_db2.js
_vc_*.js
__obsolete_next_cache_*/

# Build caches inside seed scripts dir
seed/*.db
seed/*.db-wal

# Keep only the public-facing screenshot capture script in scripts/
!scripts/screenshots.ts
.vercel
